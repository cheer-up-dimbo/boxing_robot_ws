digraph CVIMUFusion {
    bgcolor="#0B0F14";
    pad=0.5;
    nodesep=0.5;
    ranksep=0.9;
    fontname="Inter, Helvetica, Arial, sans-serif";
    label="CV + IMU Sensor Fusion Pipeline";
    labelloc=t;
    fontcolor="#E6EDF3";
    fontsize=16;

    edge [
        fontcolor="#8B949E",
        fontsize=9,
        fontname="Inter, Helvetica, Arial, sans-serif",
        arrowsize=0.7
    ];

    node [
        shape=box, style="filled,rounded",
        fontname="Inter, Helvetica, Arial, sans-serif",
        fontsize=11, fontcolor="#E6EDF3",
        penwidth=1.5
    ];

    // ── Sensors ─────────────────────────────────────────────────
    node [fillcolor="#1A1E28", color="#42A5F5"];
    camera [label="RealSense D435i\n(RGB 960x540 + Depth 640x480\n@30fps)", shape=box3d];
    imu_pads [label="Teensy 4.1 IMU Pads\n(4 accelerometers @100Hz\ncentre, left, right, head)", shape=box3d];
    arm_imu [label="Robot Arm IMU\n(2 accelerometers\ncontact detection)", shape=box3d];

    // ── CV Branch ───────────────────────────────────────────────
    node [fillcolor="#1E2832", color="#FF6B35"];

    rgb_frame [label="RGB Frame\n(960x540)"];
    depth_frame [label="Depth Frame\n(640x480)"];

    yolo [label="YOLO Pose\n(TensorRT FP16)\n~6ms inference"];
    voxel [label="Voxel Occupancy Grid\n(12x12x12, 2 channels)\nDelta @2 frames (67ms)\nDelta @8 frames (267ms)"];
    pose_feat [label="Pose Features (42 dims)\nJoint coords, velocities,\nelbow angles, arm extension"];

    temporal [label="Temporal Window\n(12 frames = 400ms @30fps)\nRolling Feature Buffer"];
    transformer [label="FusionVoxelPose\nTransformerModel\n(TensorRT FP16)\n~8ms inference"];

    smoothing [label="Post-Processing\nEMA (a=0.35)\nHysteresis (0.12)\nState Machine (3 frame hold)"];

    cv_detection [label="CV Detection\n(punch_type, confidence,\nconsecutive_frames)", color="#FFD54F", fillcolor="#231810"];

    camera -> rgb_frame [color="#42A5F5"];
    camera -> depth_frame [color="#42A5F5"];
    rgb_frame -> yolo [color="#FF6B35"];
    depth_frame -> voxel [color="#FF6B35"];
    yolo -> pose_feat [color="#FF6B35"];
    voxel -> temporal [color="#FF6B35"];
    pose_feat -> temporal [color="#FF6B35"];
    temporal -> transformer [color="#FF6B35"];
    transformer -> smoothing [color="#FF6B35"];
    smoothing -> cv_detection [color="#FFD54F"];

    // ── IMU Branch ──────────────────────────────────────────────
    node [fillcolor="#1E2832", color="#26A69A"];

    imu_raw [label="Raw Accelerometer\n(gravity-calibrated)\nthreshold: 5.0 m/s2"];
    imu_debounce [label="Per-Pad Debounce\n(150ms cooldown)"];
    pad_map [label="Pad Mapping\n0=centre, 1=right\n2=left, 3=head"];
    imu_event [label="IMU Punch Event\n(pad, force_normalized,\naccel_magnitude)", color="#FFD54F", fillcolor="#231810"];

    imu_pads -> imu_raw [color="#26A69A"];
    imu_raw -> imu_debounce [color="#26A69A"];
    imu_debounce -> pad_map [color="#26A69A"];
    pad_map -> imu_event [color="#FFD54F"];

    // ── Fusion Engine ───────────────────────────────────────────
    node [fillcolor="#1E2832", color="#FFD54F"];

    cv_buffer [label="CV Ring Buffer\n(max 50, 2s expiry)"];
    imu_buffer [label="IMU Ring Buffer\n(max 50, 2s expiry)"];

    matcher [label="Temporal Matcher\n(500ms fusion window)\nClosest timestamp match"];

    pad_constraint [label="Pad Constraint Filter\njab/cross -> centre\nL hook/L upper -> left\nR hook/R upper -> right\nall -> head"];

    reclassify [label="Reclassification\nIf invalid for pad:\ncheck secondary class\n(conf >= 0.25)"];

    node [color="#00E676", fillcolor="#1E2832"];
    confirmed [label="ConfirmedPunch\n(type, pad, force,\ncv_conf, imu_confirmed,\naccel_magnitude)"];

    cv_detection -> cv_buffer [color="#FFD54F"];
    imu_event -> imu_buffer [color="#FFD54F"];
    cv_buffer -> matcher [color="#FFD54F"];
    imu_buffer -> matcher [color="#FFD54F"];
    matcher -> pad_constraint [color="#FFD54F"];
    pad_constraint -> reclassify [label="invalid?", color="#FF5252", fontcolor="#FF5252"];
    pad_constraint -> confirmed [label="valid", color="#00E676", fontcolor="#00E676"];
    reclassify -> confirmed [label="reclassified\nor unclassified", color="#FF9800", fontcolor="#FF9800"];

    // ── Fallback Paths ──────────────────────────────────────────
    node [fillcolor="#131920", color="#78909C", fontsize=10];
    cv_only [label="CV-Only Path\n(>= 3 frames, >= 0.7 conf)\nconfidence penalty: -0.3"];
    imu_only [label="IMU-Only Path\n(no CV match)\ndefault conf: 0.3\ninfer type from pad"];

    cv_buffer -> cv_only [label="no IMU\nmatch", color="#78909C", fontcolor="#78909C", style=dashed];
    imu_buffer -> imu_only [label="no CV\nmatch", color="#78909C", fontcolor="#78909C", style=dashed];
    cv_only -> confirmed [color="#78909C", style=dashed];
    imu_only -> confirmed [color="#78909C", style=dashed];

    // ── Defense Detection ───────────────────────────────────────
    node [fillcolor="#1E2832", color="#FF5252"];

    robot_punch [label="Robot Punch\n(arm_event from IMU)"];
    defense_window [label="Defense Window\n(500ms after robot attack)"];
    defense_classify [label="Defense Classification\nBlock: CV block >= 0.3\nSlip: lateral >= 40px or depth >= 0.15m\nDodge: lateral >= 20px or depth >= 0.08m\nHit: arm IMU contact"];
    defense_event [label="DefenseEvent\n(struck, defense_type,\nreaction_time_ms)", color="#FF5252", fillcolor="#231810"];

    arm_imu -> robot_punch [color="#FF5252"];
    robot_punch -> defense_window [color="#FF5252"];
    defense_window -> defense_classify [color="#FF5252"];
    defense_classify -> defense_event [color="#FF5252"];

    // ── Downstream ──────────────────────────────────────────────
    node [fillcolor="#1E2832", color="#CE93D8"];
    session_mgr [label="Session Manager\n(accumulates stats)"];
    analytics [label="Analytics Node\n(publishes JSON)"];
    drill_mgr [label="Drill Manager\n(combo validation)"];

    confirmed -> session_mgr [color="#00E676"];
    confirmed -> analytics [color="#00E676", style=dashed];
    confirmed -> drill_mgr [color="#00E676", style=dashed];
    defense_event -> session_mgr [color="#FF5252"];
}
