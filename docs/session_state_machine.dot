digraph SessionStateMachine {
    bgcolor="#0B0F14";
    pad=0.4;
    nodesep=0.8;
    ranksep=1.0;
    fontname="Inter, Helvetica, Arial, sans-serif";
    label="Session State Machine";
    labelloc=t;
    fontcolor="#E6EDF3";
    fontsize=16;

    edge [
        fontcolor="#8B949E",
        fontsize=10,
        fontname="Inter, Helvetica, Arial, sans-serif",
        arrowsize=0.8
    ];

    node [
        shape=box, style="filled,rounded",
        fontname="Inter, Helvetica, Arial, sans-serif",
        fontsize=12, fontcolor="#E6EDF3",
        penwidth=2
    ];

    idle [
        label="IDLE\n(waiting for session)",
        fillcolor="#1E2832", color="#8B949E"
    ];
    countdown [
        label="COUNTDOWN\n(3... 2... 1...)",
        fillcolor="#1E2832", color="#FFD54F"
    ];
    active [
        label="ACTIVE\n(punching / training)",
        fillcolor="#1E2832", color="#00E676"
    ];
    rest [
        label="REST\n(between rounds)",
        fillcolor="#1E2832", color="#42A5F5"
    ];
    complete [
        label="COMPLETE\n(session finished)",
        fillcolor="#1E2832", color="#FF6B35"
    ];

    idle -> countdown [
        label="StartSession\nservice call",
        color="#FFD54F", fontcolor="#FFD54F"
    ];
    countdown -> active [
        label="countdown\nfinished (3s)",
        color="#00E676", fontcolor="#00E676"
    ];
    active -> rest [
        label="round timer\nexpired",
        color="#42A5F5", fontcolor="#42A5F5"
    ];
    rest -> countdown [
        label="rest timer\nexpired",
        color="#FFD54F", fontcolor="#FFD54F"
    ];
    active -> complete [
        label="final round\ncompleted",
        color="#FF6B35", fontcolor="#FF6B35"
    ];
    complete -> idle [
        label="auto-reset\n(3s delay)",
        color="#8B949E", fontcolor="#8B949E",
        style=dashed
    ];
    active -> complete [
        label="EndSession\nservice call",
        color="#FF5252", fontcolor="#FF5252",
        style=dashed
    ];

    // Side effects
    node [
        shape=note, style=filled, fillcolor="#131920",
        fontsize=9, fontcolor="#8B949E",
        color="#2A3040", penwidth=1
    ];

    note_active [label="IMU mode: training\nCV: 30fps\nPunches counted"];
    note_rest [label="IMU mode: navigation\nCV: idle (reduced load)\nRest timer shown"];
    note_complete [label="Summary published\nSession saved to DB\nResults page shown"];

    active -> note_active [style=dotted, color="#2A3040", arrowhead=none];
    rest -> note_rest [style=dotted, color="#2A3040", arrowhead=none];
    complete -> note_complete [style=dotted, color="#2A3040", arrowhead=none];
}
